@{
    ViewData["Title"] = "Tạo Workspace";
}

<div class="row justify-content-center">
    <div class="col-lg-6">
        <div class="card">
            <div class="card-header d-flex align-items-center gap-2">
                <i class="fas fa-th-large text-primary"></i>
                <span>Tạo Workspace mới</span>
            </div>
            <div class="card-body">
                @if (ViewBag.Error != null)
                {
                    <div class="alert alert-danger py-2">
                        <i class="fas fa-exclamation-circle me-2"></i>@ViewBag.Error
                    </div>
                }

                <form method="post" asp-action="Create">
                    <div class="mb-3">
                        <label class="form-label">Tên Workspace <span class="text-danger">*</span></label>
                        <input type="text" name="tenWorkspace" class="form-control" placeholder="VD: Công ty ABC" required />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Mô tả</label>
                        <textarea name="moTa" class="form-control" rows="3" placeholder="Mô tả về không gian làm việc"></textarea>
                    </div>
                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-primary-custom">
                            <i class="fas fa-save me-2"></i>Tạo Workspace
                        </button>
                        <a href="@Url.Action("Index")" class="btn btn-outline-custom">Hủy</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
