@model QuanLyDuAn.Models.Invitelink
@{
    ViewData["Title"] = "Lời mời tham gia dự án";
    Layout = "_Layout";
}

<div class="auth-wrapper">
    <div class="auth-card text-center fade-in-up" style="max-width: 500px;">
        <div class="auth-logo">
            <i class="fas fa-envelope-open-text text-primary" style="font-size: 3rem; margin-bottom: 15px;"></i>
            <h2>Lời mời tham gia Không gian làm việc</h2>
            <p class="text-muted">Bạn đã nhận được lời mời tham gia cùng đội ngũ</p>
        </div>

        <div class="p-4 mb-4" style="background: var(--gray-50); border: 1px solid var(--gray-200); border-radius: 12px; text-align: left;">
            <div class="mb-3">
                <small class="text-muted d-block">Không gian làm việc</small>
                <strong style="font-size: 1.1rem; color: var(--gray-800);">@Model.MaWorkspaceNavigation.TenWorkspace</strong>
            </div>
            <div class="mb-3">
                <small class="text-muted d-block">Người mời</small>
                <strong>@Model.MaWorkspaceNavigation.MaTaiKhoanNavigation.HoTen</strong> (@Model.MaWorkspaceNavigation.MaTaiKhoanNavigation.Email)
            </div>
            <div>
                <small class="text-muted d-block">Vai trò đề xuất của bạn</small>
                <span class="badge-status badge-chua">@Model.VaiTroMacDinh</span>
            </div>
        </div>

        <form method="post" asp-action="AcceptJoin">
            <input type="hidden" name="token" value="@Model.Token" />
            <button type="submit" class="btn btn-primary-custom w-100 py-2 fs-6 mb-2">
                <i class="fas fa-check me-2"></i>Xác nhận tham gia
            </button>
            <a href="/" class="btn btn-outline-custom w-100 py-2">
                Từ chối
            </a>
        </form>
    </div>
</div>
