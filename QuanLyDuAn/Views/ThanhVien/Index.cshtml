@model List<QuanLyDuAn.Models.Thanhvien>
@{
    ViewData["Title"] = "Quản lý Thành viên";
    var workspaces = ViewBag.Workspaces as List<QuanLyDuAn.Models.Workspace>;
    var inviteLinks = ViewBag.InviteLinks as List<QuanLyDuAn.Models.Invitelink>;
}

<div class="d-flex flex-wrap justify-content-between align-items-center mb-4 gap-3">
    <div>
        <h4 class="fw-bold mb-1">Quản lý Thành viên</h4>
        <p class="text-muted mb-0" style="font-size:.88rem;">@Model.Count thành viên trong dự án</p>
    </div>
    <button class="btn btn-primary-custom" data-bs-toggle="modal" data-bs-target="#inviteModal">
        <i class="fas fa-link me-2"></i>Tạo Link mời
    </button>
</div>

@if (TempData["InviteLink"] != null)
{
    <div class="alert alert-info d-flex align-items-center gap-3">
        <i class="fas fa-link fa-lg"></i>
        <div class="flex-grow-1">
            <strong>Link mời đã tạo:</strong>
            <div class="d-flex gap-2 mt-1">
                <input type="text" class="form-control form-control-sm" value="@TempData["InviteLink"]" id="inviteLinkText" readonly />
                <button class="btn btn-sm btn-outline-custom" onclick="navigator.clipboard.writeText(document.getElementById('inviteLinkText').value);this.innerHTML='<i class=\'fas fa-check\'></i> Copied!';">
                    <i class="fas fa-copy"></i> Copy
                </button>
            </div>
        </div>
    </div>
}

<!-- Members Table -->
<div class="card">
    <div class="table-responsive">
        <table class="table-custom">
            <thead>
                <tr>
                    <th>Thành viên</th>
                    <th>Email</th>
                    <th>Dự án</th>
                    <th>Vai trò dự án</th>
                    <th>Ngày tham gia</th>
                </tr>
            </thead>
            <tbody>
                @if (Model.Count == 0)
                {
                    <tr><td colspan="5" class="text-center text-muted py-4">Chưa có thành viên nào</td></tr>
                }
                else
                {
                    foreach (var tv in Model)
                    {
                        <tr>
                            <td>
                                <div class="d-flex align-items-center gap-2">
                                    <div class="user-avatar" style="width:32px;height:32px;font-size:.75rem;">
                                        @tv.MaTaiKhoanNavigation.HoTen[0].ToString().ToUpper()
                                    </div>
                                    <span class="fw-semibold">@tv.MaTaiKhoanNavigation.HoTen</span>
                                </div>
                            </td>
                            <td style="font-size:.85rem;">@tv.MaTaiKhoanNavigation.Email</td>
                            <td style="font-size:.85rem;">@tv.MaDuAnNavigation.TenDuAn</td>
                            <td><span class="badge-status badge-chua">@tv.VaiTroDuAn</span></td>
                            <td style="font-size:.85rem;">@tv.NgayThamGia.ToString("dd/MM/yyyy")</td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
</div>

<!-- Invite Link Modal -->
<div class="modal fade" id="inviteModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title fw-bold"><i class="fas fa-link me-2"></i>Khởi tạo Link mời</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <form method="post" asp-action="GenerateInviteLink">
                <div class="modal-body">
                    <div class="mb-3">
                        <label class="form-label">Chọn Workspace</label>
                        <select name="maWorkspace" class="form-select" required>
                            @if (workspaces != null)
                            {
                                foreach (var ws in workspaces)
                                {
                                    <option value="@ws.MaWorkspace">@ws.TenWorkspace</option>
                                }
                            }
                        </select>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Vai trò mặc định</label>
                        <select name="vaiTroMacDinh" class="form-select">
                            <option value="Member">Member (Thành viên)</option>
                            <option value="Manager">Manager (Quản lý)</option>
                        </select>
                    </div>
                    <p class="text-muted" style="font-size:.82rem;">
                        <i class="fas fa-info-circle me-1"></i>
                        Link mời có hiệu lực trong 7 ngày kể từ lúc tạo.
                    </p>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-outline-custom" data-bs-dismiss="modal">Hủy</button>
                    <button type="submit" class="btn btn-primary-custom">
                        <i class="fas fa-magic me-2"></i>Tạo Link
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>
