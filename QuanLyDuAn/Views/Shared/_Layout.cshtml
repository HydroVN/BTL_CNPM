@inject QuanLyDuAn.Data.BtlCnpmContext _dbContext
@{
    var hoTen = Context.Session.GetString("HoTen") ?? "";
    var vaiTro = Context.Session.GetString("VaiTro") ?? "";
    var email = Context.Session.GetString("Email") ?? "";
    var isLoggedIn = !string.IsNullOrEmpty(Context.Session.GetString("MaTaiKhoan"));

    List<QuanLyDuAn.Models.Thongbao> notifications = new();
    if (isLoggedIn)
    {
        var maTk = Context.Session.GetString("MaTaiKhoan");
        notifications = _dbContext.Thongbaos
            .Where(t => t.MaTaiKhoan == maTk)
            .OrderByDescending(t => t.ThoiGian)
            .Take(10)
            .ToList();
    }
}
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Quản Lý Dự Án</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" />
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    @await RenderSectionAsync("Styles", required: false)
</head>
<body>
    @if (isLoggedIn)
    {
        <div class="app-wrapper">
            <!-- Sidebar -->
            <aside class="sidebar" id="sidebar">
                <div class="sidebar-header">
                    <div class="sidebar-logo">
                        <i class="fas fa-project-diagram"></i>
                        <span>ProjectFlow</span>
                    </div>
                    <button class="sidebar-toggle d-lg-none" onclick="toggleSidebar()">
                        <i class="fas fa-times"></i>
                    </button>
                </div>

                <nav class="sidebar-nav">
                    <div class="nav-section">
                        <span class="nav-section-title">TỔNG QUAN</span>
                        <a href="@Url.Action("Index", "Workspace")" class="nav-link-item @(ViewContext.RouteData.Values["controller"]?.ToString() == "Workspace" ? "active" : "")">
                            <i class="fas fa-th-large"></i>
                            <span>Workspace</span>
                        </a>
                        <a href="@Url.Action("Index", "DuAn")" class="nav-link-item @(ViewContext.RouteData.Values["controller"]?.ToString() == "DuAn" && ViewContext.RouteData.Values["action"]?.ToString() == "Index" ? "active" : "")">
                            <i class="fas fa-folder-open"></i>
                            <span>Dự án</span>
                        </a>
                    </div>

                    @if (vaiTro == "Admin" || vaiTro == "Manager")
                    {
                        <div class="nav-section">
                            <span class="nav-section-title">QUẢN LÝ</span>
                            <a href="@Url.Action("Index", "ThanhVien")" class="nav-link-item @(ViewContext.RouteData.Values["controller"]?.ToString() == "ThanhVien" && ViewContext.RouteData.Values["action"]?.ToString() == "Index" ? "active" : "")">
                                <i class="fas fa-users"></i>
                                <span>Thành viên</span>
                            </a>
                            <a href="@Url.Action("TienDo", "BaoCao")" class="nav-link-item @(ViewContext.RouteData.Values["controller"]?.ToString() == "BaoCao" ? "active" : "")">
                                <i class="fas fa-chart-bar"></i>
                                <span>Báo cáo</span>
                            </a>
                            @if (vaiTro == "Admin")
                            {
                                <a href="@Url.Action("AdminUsers", "ThanhVien")" class="nav-link-item @(ViewContext.RouteData.Values["controller"]?.ToString() == "ThanhVien" && ViewContext.RouteData.Values["action"]?.ToString() == "AdminUsers" ? "active" : "")">
                                    <i class="fas fa-user-shield text-danger"></i>
                                    <span>Quản trị tài khoản</span>
                                </a>
                            }
                        </div>
                    }

                    <div class="nav-section">
                        <span class="nav-section-title">TÀI KHOẢN</span>
                        <a href="@Url.Action("Profile", "Account")" class="nav-link-item @(ViewContext.RouteData.Values["action"]?.ToString() == "Profile" ? "active" : "")">
                            <i class="fas fa-user-circle"></i>
                            <span>Hồ sơ cá nhân</span>
                        </a>
                        <a href="@Url.Action("ChangePassword", "Account")" class="nav-link-item @(ViewContext.RouteData.Values["action"]?.ToString() == "ChangePassword" ? "active" : "")">
                            <i class="fas fa-key"></i>
                            <span>Đổi mật khẩu</span>
                        </a>
                    </div>
                </nav>
            </aside>

            <!-- Main Content -->
            <div class="main-content">
                <!-- Topbar -->
                <header class="topbar">
                    <div class="topbar-left">
                        <button class="sidebar-toggle d-lg-none" onclick="toggleSidebar()">
                            <i class="fas fa-bars"></i>
                        </button>
                        <h5 class="page-title mb-0">@ViewData["Title"]</h5>
                    </div>
                    <div class="topbar-right">
                        <!-- Notifications Dropdown -->
                        <div class="dropdown me-2">
                            <button class="btn btn-link position-relative text-dark p-2" id="notificationDropdown" data-bs-toggle="dropdown" aria-expanded="false" style="border: 1px solid var(--gray-200); border-radius: 50%; width: 36px; height: 36px; display: flex; align-items: center; justify-content: center; text-decoration: none; background: #fff;">
                                <i class="fas fa-bell" style="font-size: 1.1rem; color: var(--gray-600);"></i>
                                @{
                                    var unreadCount = notifications.Count(t => t.TrangThai == "ChuaDoc");
                                    if (unreadCount > 0)
                                    {
                                        <span class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger" style="font-size: 0.65rem; padding: 0.25em 0.5em;">
                                            @unreadCount
                                        </span>
                                    }
                                }
                            </button>
                            <div class="dropdown-menu dropdown-menu-end p-0 shadow-lg" aria-labelledby="notificationDropdown" style="width: 320px; border-radius: 8px; overflow: hidden; max-height: 400px; overflow-y: auto;">
                                <div class="p-3 border-bottom bg-light d-flex justify-content-between align-items-center">
                                    <h6 class="fw-bold mb-0">Thông báo</h6>
                                    @if (unreadCount > 0)
                                    {
                                        <span class="badge bg-primary-light text-primary" style="font-size: 0.75rem;">@unreadCount mới</span>
                                    }
                                </div>
                                <div class="list-group list-group-flush">
                                    @if (notifications.Count == 0)
                                    {
                                        <div class="p-3 text-center text-muted" style="font-size: 0.85rem;">Không có thông báo nào</div>
                                    }
                                    else
                                    {
                                        foreach (var notif in notifications)
                                        {
                                            var isUnread = notif.TrangThai == "ChuaDoc";
                                            var isInvite = notif.NoiDung.StartsWith("PROJECT_INVITE|");
                                            
                                            <div class="list-group-item p-3 @(isUnread ? "bg-light" : "")" style="font-size: 0.85rem; border-bottom: 1px solid var(--gray-100);">
                                                <div class="d-flex justify-content-between align-items-start mb-1">
                                                    <span class="small text-muted">@notif.ThoiGian.ToString("dd/MM/yyyy HH:mm")</span>
                                                    @if (isUnread)
                                                    {
                                                        <span class="badge bg-success" style="font-size: 0.6rem; padding: 0.2em 0.4em;">Mới</span>
                                                    }
                                                </div>
                                                
                                                @if (isInvite)
                                                {
                                                    var parts = notif.NoiDung.Split('|');
                                                    var inviteMsg = parts.Length >= 4 ? parts[3] : "Bạn có lời mời tham gia dự án.";
                                                    <p class="mb-2 text-dark">@inviteMsg</p>
                                                    
                                                    // Only show action buttons if it's still an active invitation
                                                    if (notif.NoiDung.StartsWith("PROJECT_INVITE|"))
                                                    {
                                                        <div class="d-flex gap-2">
                                                            <form method="post" asp-controller="ThanhVien" asp-action="AcceptProjectInvite" style="display:inline;">
                                                                <input type="hidden" name="notificationId" value="@notif.MaThongBao" />
                                                                <button type="submit" class="btn btn-sm btn-primary-custom py-1 px-2" style="font-size: 0.75rem;">Xác nhận</button>
                                                            </form>
                                                            <form method="post" asp-controller="ThanhVien" asp-action="DeclineProjectInvite" style="display:inline;">
                                                                <input type="hidden" name="notificationId" value="@notif.MaThongBao" />
                                                                <button type="submit" class="btn btn-sm btn-outline-custom py-1 px-2" style="font-size: 0.75rem;">Từ chối</button>
                                                            </form>
                                                        </div>
                                                    }
                                                }
                                                else
                                                {
                                                    <p class="mb-0 text-dark">@notif.NoiDung</p>
                                                }
                                            </div>
                                        }
                                    }
                                </div>
                            </div>
                        </div>

                        <!-- User Profile -->
                        <div class="dropdown">
                            <button class="user-menu" data-bs-toggle="dropdown" aria-expanded="false">
                                <div class="user-avatar">
                                    @(hoTen.Length > 0 ? hoTen[0].ToString().ToUpper() : "U")
                                </div>
                                <div class="user-info d-none d-md-block">
                                    <span class="user-name">@hoTen</span>
                                    <span class="user-role">@vaiTro</span>
                                </div>
                                <i class="fas fa-chevron-down ms-2"></i>
                            </button>
                            <ul class="dropdown-menu dropdown-menu-end">
                                <li><a class="dropdown-item" href="@Url.Action("Profile", "Account")"><i class="fas fa-user me-2"></i>Hồ sơ cá nhân</a></li>
                                <li><a class="dropdown-item" href="@Url.Action("ChangePassword", "Account")"><i class="fas fa-key me-2"></i>Đổi mật khẩu</a></li>
                                <li><hr class="dropdown-divider" /></li>
                                <li><a class="dropdown-item text-danger" href="@Url.Action("Logout", "Account")"><i class="fas fa-sign-out-alt me-2"></i>Đăng xuất</a></li>
                            </ul>
                        </div>
                    </div>
                </header>

                <!-- Page Content -->
                <div class="page-content">
                    @if (TempData["Success"] != null)
                    {
                        <div class="alert alert-success alert-dismissible fade show" role="alert">
                            <i class="fas fa-check-circle me-2"></i>@TempData["Success"]
                            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                        </div>
                    }
                    @if (TempData["Error"] != null)
                    {
                        <div class="alert alert-danger alert-dismissible fade show" role="alert">
                            <i class="fas fa-exclamation-circle me-2"></i>@TempData["Error"]
                            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                        </div>
                    }
                    @RenderBody()
                </div>
            </div>
        </div>

        <!-- Overlay for mobile sidebar -->
        <div class="sidebar-overlay" id="sidebarOverlay" onclick="toggleSidebar()"></div>
    }
    else
    {
        @RenderBody()
    }

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
