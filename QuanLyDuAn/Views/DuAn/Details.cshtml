@model QuanLyDuAn.Models.Duan
@{
    ViewData["Title"] = "Chi tiết dự án";
    var totalTasks = Model.Congviecs.Count;
    var doneTasks = Model.Congviecs.Count(c => c.TrangThai == "Done");
    var inProgressTasks = Model.Congviecs.Count(c => c.TrangThai == "InProgress");
    var todoTasks = Model.Congviecs.Count(c => c.TrangThai == "ToDo");
    var reviewTasks = Model.Congviecs.Count(c => c.TrangThai == "Review");
    var progress = totalTasks > 0 ? (int)(doneTasks * 100.0 / totalTasks) : 0;

    var currentUserId = Context.Session.GetString("MaTaiKhoan");
    var currentUserRole = Context.Session.GetString("VaiTro");
    var isWorkspaceOwner = Model.MaWorkspaceNavigation?.MaTaiKhoan == currentUserId;
    var isPm = Model.Thanhviens.Any(tv => tv.MaTaiKhoan == currentUserId && tv.VaiTroDuAn == "PM");
    var isAuthorizedToManage = isWorkspaceOwner || isPm || currentUserRole == "Admin";
}

<!-- Header -->
<div class="d-flex flex-wrap justify-content-between align-items-start mb-4 gap-3">
    <div>
        <h4 class="fw-bold mb-1">@Model.TenDuAn</h4>
        <p class="text-muted mb-0" style="font-size:.88rem;">
            Workspace: <strong>@Model.MaWorkspaceNavigation?.TenWorkspace</strong>
            &nbsp;|&nbsp; Mã: <code>@Model.MaDuAn</code>
        </p>
    </div>
    <div class="d-flex gap-2">
        <a href="@Url.Action("Board", "CongViec", new { maDuAn = Model.MaDuAn })" class="btn btn-primary-custom">
            <i class="fas fa-columns me-2"></i>Board View
        </a>
        @if (isAuthorizedToManage)
        {
            <a href="@Url.Action("Edit", new { id = Model.MaDuAn })" class="btn btn-outline-custom">
                <i class="fas fa-edit me-2"></i>Sửa
            </a>
        }
    </div>
</div>

<!-- Stats -->
<div class="row g-3 mb-4">
    <div class="col-6 col-lg-3">
        <div class="stat-card stat-primary">
            <div class="stat-icon"><i class="fas fa-tasks"></i></div>
            <div class="stat-value">@totalTasks</div>
            <div class="stat-label">Tổng công việc</div>
        </div>
    </div>
    <div class="col-6 col-lg-3">
        <div class="stat-card stat-warning">
            <div class="stat-icon"><i class="fas fa-spinner"></i></div>
            <div class="stat-value">@inProgressTasks</div>
            <div class="stat-label">Đang thực hiện</div>
        </div>
    </div>
    <div class="col-6 col-lg-3">
        <div class="stat-card stat-success">
            <div class="stat-icon"><i class="fas fa-check-circle"></i></div>
            <div class="stat-value">@doneTasks</div>
            <div class="stat-label">Hoàn thành</div>
        </div>
    </div>
    <div class="col-6 col-lg-3">
        <div class="stat-card stat-info">
            <div class="stat-icon"><i class="fas fa-percentage"></i></div>
            <div class="stat-value">@(progress)%</div>
            <div class="stat-label">Tiến độ</div>
        </div>
    </div>
</div>

<div class="row g-4">
    <!-- Project Info -->
    <div class="col-lg-4">
        <div class="card h-100">
            <div class="card-header"><i class="fas fa-info-circle me-2"></i>Thông tin dự án</div>
            <div class="card-body">
                <div class="mb-3">
                    <small class="text-muted d-block">Trạng thái</small>
                    @{
                        string computedStatus = "ChuaThucHien";
                        if (totalTasks > 0)
                        {
                            computedStatus = (progress == 100) ? "DaHoanThanh" : "DangThucHien";
                        }
                        else
                        {
                            computedStatus = Model.TrangThai;
                        }
                        var badgeClass = computedStatus switch { "ChuaThucHien" => "badge-chua", "DangThucHien" => "badge-dang", "DaHoanThanh" => "badge-xong", _ => "badge-chua" };
                        var statusText = computedStatus switch { "ChuaThucHien" => "Chưa thực hiện", "DangThucHien" => "Đang thực hiện", "DaHoanThanh" => "Đã hoàn thành", _ => computedStatus };
                    }
                    <span class="badge-status @badgeClass">@statusText</span>
                </div>
                <div class="mb-3">
                    <small class="text-muted d-block">Ngày bắt đầu</small>
                    <strong>@(Model.NgayBatDau?.ToString("dd/MM/yyyy") ?? "Chưa đặt")</strong>
                </div>
                <div class="mb-3">
                    <small class="text-muted d-block">Ngày kết thúc</small>
                    <strong>@(Model.NgayKetThuc?.ToString("dd/MM/yyyy") ?? "Chưa đặt")</strong>
                </div>
                <div class="mb-3">
                    <small class="text-muted d-block">Mô tả</small>
                    <p class="mb-0" style="font-size:.88rem;">@(Model.MoTa ?? "Không có mô tả")</p>
                </div>
                <div>
                    <small class="text-muted d-block mb-1">Tiến độ tổng thể</small>
                    <div class="progress-custom">
                        <div class="progress-bar" style="width:@(progress)%"></div>
                    </div>
                    <small class="text-muted">@doneTasks/@totalTasks công việc hoàn thành</small>
                </div>
            </div>
        </div>
    </div>

    <!-- Members -->
    <div class="col-lg-4">
        <div class="card h-100">
            <div class="card-header d-flex justify-content-between align-items-center">
                <span><i class="fas fa-users me-2"></i>Thành viên (@Model.Thanhviens.Count)</span>
                @if (isAuthorizedToManage)
                {
                    <a href="@Url.Action("AddToProject", "ThanhVien", new { maDuAn = Model.MaDuAn })" class="btn btn-sm btn-primary-custom">
                        <i class="fas fa-plus"></i>
                    </a>
                }
            </div>
            <div class="card-body">
                @if (Model.Thanhviens.Count == 0)
                {
                    <p class="text-muted text-center" style="font-size:.88rem;">Chưa có thành viên</p>
                }
                else
                {
                    foreach (var tv in Model.Thanhviens)
                    {
                        var isMemberOwner = Model.MaWorkspaceNavigation?.MaTaiKhoan == tv.MaTaiKhoan;
                        <div class="d-flex align-items-center gap-3 mb-3">
                            <div class="user-avatar" style="width:36px;height:36px;font-size:.8rem;">
                                @tv.MaTaiKhoanNavigation.HoTen[0].ToString().ToUpper()
                            </div>
                            <div class="flex-grow-1">
                                <div class="fw-semibold" style="font-size:.88rem;">@tv.MaTaiKhoanNavigation.HoTen</div>
                                <small class="text-muted">@tv.VaiTroDuAn</small>
                            </div>
                            @if (isAuthorizedToManage && !isMemberOwner)
                            {
                                <div class="d-flex gap-1">
                                    <button class="btn btn-xs btn-outline-custom p-1" onclick="openEditRoleModal('@tv.MaThanhVien', '@tv.MaTaiKhoanNavigation.HoTen', '@tv.VaiTroDuAn')" title="Sửa vai trò" style="line-height:1; padding: 2px 5px !important;">
                                        <i class="fas fa-edit" style="font-size: 0.75rem;"></i>
                                    </button>
                                    <form method="post" asp-controller="ThanhVien" asp-action="RemoveMember" style="display:inline;" onsubmit="return confirm('Bạn có chắc chắn muốn xóa thành viên @tv.MaTaiKhoanNavigation.HoTen khỏi dự án này?');">
                                        <input type="hidden" name="maThanhVien" value="@tv.MaThanhVien" />
                                        <input type="hidden" name="maDuAn" value="@Model.MaDuAn" />
                                        <button type="submit" class="btn btn-xs btn-outline-danger p-1" title="Xóa thành viên" style="line-height:1; padding: 2px 5px !important;">
                                            <i class="fas fa-trash-alt" style="font-size: 0.75rem;"></i>
                                        </button>
                                    </form>
                                </div>
                            }
                        </div>
                    }
                }
            </div>
        </div>
    </div>

    <!-- Tasks List -->
    <div class="col-lg-4">
        <div class="card h-100">
            <div class="card-header d-flex justify-content-between align-items-center">
                <span><i class="fas fa-list-check me-2"></i>Công việc (@totalTasks)</span>
                @if (isAuthorizedToManage)
                {
                    <a href="@Url.Action("Create", "CongViec", new { maDuAn = Model.MaDuAn })" class="btn btn-sm btn-primary-custom">
                        <i class="fas fa-plus"></i>
                    </a>
                }
            </div>
            <div class="card-body" style="max-height:350px;overflow-y:auto;">
                @if (totalTasks == 0)
                {
                    <p class="text-muted text-center" style="font-size:.88rem;">Chưa có công việc</p>
                }
                else
                {
                    foreach (var cv in Model.Congviecs.OrderBy(c => c.TrangThai))
                    {
                        var taskBadge = cv.TrangThai switch { "ToDo" => "badge-todo", "InProgress" => "badge-inprogress", "Review" => "badge-review", "Done" => "badge-done", _ => "badge-todo" };
                        <div class="d-flex justify-content-between align-items-center py-2" style="border-bottom:1px solid var(--gray-100);">
                            <div>
                                <div class="fw-semibold" style="font-size:.85rem;">@cv.TenCongViec</div>
                                <small class="text-muted">
                                    @(cv.MaThanhVienNavigation?.MaTaiKhoanNavigation?.HoTen ?? "Chưa phân công")
                                </small>
                            </div>
                            <span class="badge-status @taskBadge">@cv.TrangThai</span>
                        </div>
                    }
                }
            </div>
        </div>
    </div>
</div>

<!-- Modal Sửa Vai trò Thành viên -->
<div class="modal fade" id="editRoleModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content shadow-lg border-0">
            <div class="modal-header bg-light">
                <h5 class="modal-title fw-bold text-dark"><i class="fas fa-user-tag me-2 text-primary"></i>Thay đổi vai trò</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <form method="post" asp-controller="ThanhVien" asp-action="UpdateMemberRole">
                <div class="modal-body p-4">
                    <input type="hidden" id="editMemberId" name="maThanhVien" />
                    <input type="hidden" name="maDuAn" value="@Model.MaDuAn" />
                    
                    <p class="mb-3 fs-6">Thành viên: <strong id="editMemberName" class="text-primary"></strong></p>

                    <div class="mb-3">
                        <label class="form-label fw-semibold text-muted">Vai trò dự án mới</label>
                        <select id="editMemberRole" name="vaiTroDuAn" class="form-select border-2">
                            <option value="Developer">Developer (Lập trình viên)</option>
                            <option value="Tester">Tester (Kiểm thử viên)</option>
                            <option value="Designer">Designer (Thiết kế)</option>
                            <option value="PM">Project Manager (Quản lý dự án)</option>
                        </select>
                    </div>
                </div>
                <div class="modal-footer border-0 p-3 bg-light">
                    <button type="button" class="btn btn-outline-custom px-4" data-bs-dismiss="modal">Hủy</button>
                    <button type="submit" class="btn btn-primary-custom px-4">Cập nhật</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function openEditRoleModal(id, name, role) {
            $('#editMemberId').val(id);
            $('#editMemberName').text(name);
            $('#editMemberRole').val(role);
            var myModal = new bootstrap.Modal(document.getElementById('editRoleModal'));
            myModal.show();
        }
    </script>
}
