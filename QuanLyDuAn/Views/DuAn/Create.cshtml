@{
    ViewData["Title"] = "Thêm dự án mới";
    var workspaces = ViewBag.Workspaces as List<QuanLyDuAn.Models.Workspace>;
}

<div class="row justify-content-center">
    <div class="col-lg-7">
        <div class="card">
            <div class="card-header d-flex align-items-center gap-2">
                <i class="fas fa-folder-plus text-primary"></i>
                <span>Thêm dự án mới</span>
            </div>
            <div class="card-body">
                @if (ViewBag.Error != null)
                {
                    <div class="alert alert-danger py-2">
                        <i class="fas fa-exclamation-circle me-2"></i>@ViewBag.Error
                    </div>
                }

                <form method="post" asp-action="Create">
                    <div class="mb-3">
                        <label class="form-label">Workspace <span class="text-danger">*</span></label>
                        <select name="maWorkspace" class="form-select" required>
                            <option value="">-- Chọn Workspace --</option>
                            @if (workspaces != null)
                            {
                                foreach (var ws in workspaces)
                                {
                                    <option value="@ws.MaWorkspace">@ws.TenWorkspace</option>
                                }
                            }
                        </select>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Tên dự án <span class="text-danger">*</span></label>
                        <input type="text" name="tenDuAn" class="form-control" placeholder="Nhập tên dự án" required />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Mô tả</label>
                        <textarea name="moTa" class="form-control" rows="3" placeholder="Mô tả mục tiêu dự án"></textarea>
                    </div>
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="form-label">Ngày bắt đầu</label>
                            <input type="text" name="ngayBatDau" class="form-control datepicker" placeholder="dd/mm/yyyy" />
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label">Ngày kết thúc dự kiến</label>
                            <input type="text" name="ngayKetThuc" class="form-control datepicker" placeholder="dd/mm/yyyy" />
                        </div>
                    </div>
                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-primary-custom">
                            <i class="fas fa-save me-2"></i>Lưu dự án
                        </button>
                        <a href="@Url.Action("Index")" class="btn btn-outline-custom">Hủy</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/flatpickr/dist/flatpickr.min.css">
    <script src="https://cdn.jsdelivr.net/npm/flatpickr"></script>
    <script src="https://cdn.jsdelivr.net/npm/flatpickr/dist/l10n/vn.js"></script>
    <script>
        $(document).ready(function() {
            flatpickr(".datepicker", {
                locale: "vn",
                altInput: true,
                altFormat: "d/m/Y",
                dateFormat: "Y-m-d",
                allowInput: true,
                onReady: function(selectedDates, dateStr, instance) {
                    var altInput = instance.altInput;
                    if (altInput) {
                        altInput.placeholder = "dd/mm/yyyy";
                        altInput.addEventListener('input', function(e) {
                            var cursorPosition = this.selectionStart;
                            var originalLength = this.value.length;
                            
                            var value = this.value.replace(/\D/g, ''); // Keep only digits
                            var formatted = '';
                            
                            if (value.length > 0) {
                                var day = value.substring(0, 2);
                                formatted += day;
                                if (value.length > 2) {
                                    formatted += '/';
                                    var month = value.substring(2, 4);
                                    formatted += month;
                                    if (value.length > 4) {
                                        formatted += '/';
                                        var year = value.substring(4, 8);
                                        formatted += year;
                                    }
                                }
                            }
                            
                            this.value = formatted;
                            
                            var newLength = formatted.length;
                            var diff = newLength - originalLength;
                            this.setSelectionRange(cursorPosition + diff, cursorPosition + diff);
                        });
                        
                        altInput.addEventListener('blur', function() {
                            if (this.value) {
                                instance.setDate(this.value, true, "d/m/Y");
                            }
                        });
                    }
                }
            });
        });
    </script>
}
