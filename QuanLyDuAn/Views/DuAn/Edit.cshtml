@model QuanLyDuAn.Models.Duan
@{
    ViewData["Title"] = "Chỉnh sửa dự án";
}

<div class="row justify-content-center">
    <div class="col-lg-7">
        <div class="card">
            <div class="card-header d-flex align-items-center gap-2">
                <i class="fas fa-edit text-primary"></i>
                <span>Cập nhật dự án</span>
            </div>
            <div class="card-body">
                @if (ViewBag.Error != null)
                {
                    <div class="alert alert-danger py-2">
                        <i class="fas fa-exclamation-circle me-2"></i>@ViewBag.Error
                    </div>
                }

                <form method="post" asp-action="Edit">
                    <input type="hidden" name="maDuAn" value="@Model.MaDuAn" />

                    <div class="mb-3">
                        <label class="form-label">Mã dự án</label>
                        <input type="text" class="form-control" value="@Model.MaDuAn" disabled />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Tên dự án <span class="text-danger">*</span></label>
                        <input type="text" name="tenDuAn" class="form-control" value="@Model.TenDuAn" required />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Mô tả</label>
                        <textarea name="moTa" class="form-control" rows="3">@Model.MoTa</textarea>
                    </div>
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="form-label">Ngày bắt đầu</label>
                            <input type="text" name="ngayBatDau" class="form-control datepicker" value="@Model.NgayBatDau?.ToString("yyyy-MM-dd")" placeholder="dd/mm/yyyy" />
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label">Ngày kết thúc</label>
                            <input type="text" name="ngayKetThuc" class="form-control datepicker" value="@Model.NgayKetThuc?.ToString("yyyy-MM-dd")" placeholder="dd/mm/yyyy" />
                        </div>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Trạng thái</label>
                        @if (Model.Congviecs.Count > 0)
                        {
                            var total = Model.Congviecs.Count;
                            var done = Model.Congviecs.Count(c => c.TrangThai == "Done");
                            var isDone = total == done;
                            <select name="trangThai" class="form-select bg-light" disabled>
                                <option value="DangThucHien" selected="@(!isDone)">🟡 Đang thực hiện (Tự động theo tiến độ)</option>
                                <option value="DaHoanThanh" selected="@(isDone)">🔴 Đã hoàn thành (Tự động theo tiến độ)</option>
                            </select>
                            <input type="hidden" name="trangThai" value="@(isDone ? "DaHoanThanh" : "DangThucHien")" />
                            <small class="text-muted d-block mt-1"><i class="fas fa-info-circle me-1"></i>Trạng thái dự án tự động khóa theo tiến độ công việc.</small>
                        }
                        else
                        {
                            <select name="trangThai" class="form-select">
                                <option value="ChuaThucHien" selected="@(Model.TrangThai == "ChuaThucHien")">🔵 Chưa thực hiện</option>
                                <option value="DangThucHien" selected="@(Model.TrangThai == "DangThucHien")">🟡 Đang thực hiện</option>
                                <option value="DaHoanThanh" selected="@(Model.TrangThai == "DaHoanThanh")">🔴 Đã hoàn thành</option>
                            </select>
                        }
                    </div>
                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-primary-custom">
                            <i class="fas fa-save me-2"></i>Lưu thay đổi
                        </button>
                        <a href="@Url.Action("Details", new { id = Model.MaDuAn })" class="btn btn-outline-custom">Hủy</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/flatpickr/dist/flatpickr.min.css">
    <script src="https://cdn.jsdelivr.net/npm/flatpickr"></script>
    <script src="https://cdn.jsdelivr.net/npm/flatpickr/dist/l10n/vn.js"></script>
    <script>
        $(document).ready(function() {
            flatpickr(".datepicker", {
                locale: "vn",
                altInput: true,
                altFormat: "d/m/Y",
                dateFormat: "Y-m-d",
                allowInput: true,
                onReady: function(selectedDates, dateStr, instance) {
                    var altInput = instance.altInput;
                    if (altInput) {
                        altInput.placeholder = "dd/mm/yyyy";
                        altInput.addEventListener('input', function(e) {
                            var cursorPosition = this.selectionStart;
                            var originalLength = this.value.length;
                            
                            var value = this.value.replace(/\D/g, ''); // Keep only digits
                            var formatted = '';
                            
                            if (value.length > 0) {
                                var day = value.substring(0, 2);
                                formatted += day;
                                if (value.length > 2) {
                                    formatted += '/';
                                    var month = value.substring(2, 4);
                                    formatted += month;
                                    if (value.length > 4) {
                                        formatted += '/';
                                        var year = value.substring(4, 8);
                                        formatted += year;
                                    }
                                }
                            }
                            
                            this.value = formatted;
                            
                            var newLength = formatted.length;
                            var diff = newLength - originalLength;
                            this.setSelectionRange(cursorPosition + diff, cursorPosition + diff);
                        });
                        
                        altInput.addEventListener('blur', function() {
                            if (this.value) {
                                instance.setDate(this.value, true, "d/m/Y");
                            }
                        });
                    }
                }
            });
        });
    </script>
}
