@model List<QuanLyDuAn.Models.Duan>
@{
    ViewData["Title"] = "Quản lý Dự án";
    var workspaces = ViewBag.Workspaces as List<QuanLyDuAn.Models.Workspace>;
    var currentWs = ViewBag.CurrentWorkspace as string;
    var search = ViewBag.Search as string;
    var trangThai = ViewBag.TrangThai as string;
}

<div class="d-flex flex-wrap justify-content-between align-items-center mb-4 gap-3">
    <div>
        <h4 class="fw-bold mb-1">Quản lý Dự án</h4>
        <p class="text-muted mb-0" style="font-size:.88rem;">Tổng cộng <strong>@Model.Count</strong> dự án</p>
    </div>
    <a href="@Url.Action("Create")" class="btn btn-primary-custom">
        <i class="fas fa-plus me-2"></i>Thêm dự án
    </a>
</div>

<!-- Search & Filters -->
<div class="card mb-4">
    <div class="card-body py-3">
        <form method="get" asp-action="Index" class="row g-2 align-items-end">
            <div class="col-md-4">
                <div class="search-bar">
                    <i class="fas fa-search search-icon"></i>
                    <input type="text" name="search" class="form-control" placeholder="Tìm theo tên hoặc mã dự án..." value="@search" />
                </div>
            </div>
            <div class="col-md-3">
                <select name="maWorkspace" class="form-select">
                    <option value="">-- Tất cả Workspace --</option>
                    @if (workspaces != null)
                    {
                        foreach (var ws in workspaces)
                        {
                            <option value="@ws.MaWorkspace" selected="@(currentWs == ws.MaWorkspace)">@ws.TenWorkspace</option>
                        }
                    }
                </select>
            </div>
            <div class="col-md-3">
                <select name="trangThai" class="form-select">
                    <option value="">-- Tất cả trạng thái --</option>
                    <option value="ChuaThucHien" selected="@(trangThai == "ChuaThucHien")">Chưa thực hiện</option>
                    <option value="DangThucHien" selected="@(trangThai == "DangThucHien")">Đang thực hiện</option>
                    <option value="DaHoanThanh" selected="@(trangThai == "DaHoanThanh")">Đã hoàn thành</option>
                </select>
            </div>
            <div class="col-md-2">
                <button type="submit" class="btn btn-outline-custom w-100">
                    <i class="fas fa-filter me-1"></i>Lọc
                </button>
            </div>
        </form>
    </div>
</div>

@if (Model.Count == 0)
{
    <div class="empty-state">
        <i class="fas fa-folder-open d-block"></i>
        <h5>Không tìm thấy dự án nào phù hợp</h5>
        <p>Không tìm thấy dự án nào phù hợp với tiêu chí tìm kiếm của bạn.</p>
    </div>
}
else
{
    <div class="card">
        <div class="table-responsive">
            <table class="table-custom">
                <thead>
                    <tr>
                        <th>Mã</th>
                        <th>Tên dự án</th>
                        <th>Workspace</th>
                        <th>Bắt đầu</th>
                        <th>Kết thúc</th>
                        <th>Tiến độ</th>
                        <th>Trạng thái</th>
                        <th style="width:140px;">Thao tác</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var da in Model)
                    {
                        var totalTasks = da.Congviecs.Count;
                        var doneTasks = da.Congviecs.Count(c => c.TrangThai == "Done");
                        var progress = totalTasks > 0 ? (int)(doneTasks * 100.0 / totalTasks) : 0;

                        // Dynamically calculate status
                        string computedStatus = "ChuaThucHien";
                        if (totalTasks > 0)
                        {
                            computedStatus = (progress == 100) ? "DaHoanThanh" : "DangThucHien";
                        }
                        else
                        {
                            computedStatus = da.TrangThai;
                        }

                        var badgeClass = computedStatus switch
                        {
                            "ChuaThucHien" => "badge-chua",
                            "DangThucHien" => "badge-dang",
                            "DaHoanThanh" => "badge-xong",
                            _ => "badge-chua"
                        };
                        var statusText = computedStatus switch
                        {
                            "ChuaThucHien" => "Chưa thực hiện",
                            "DangThucHien" => "Đang thực hiện",
                            "DaHoanThanh" => "Đã hoàn thành",
                            _ => computedStatus
                        };

                        <tr>
                            <td><code style="font-size:.78rem;">@da.MaDuAn</code></td>
                            <td class="fw-semibold">@da.TenDuAn</td>
                            <td style="font-size:.85rem;">@da.MaWorkspaceNavigation?.TenWorkspace</td>
                            <td>@da.NgayBatDau?.ToString("dd/MM/yyyy")</td>
                            <td>@da.NgayKetThuc?.ToString("dd/MM/yyyy")</td>
                            <td style="min-width:120px;">
                                <div class="d-flex align-items-center gap-2">
                                    <div class="progress-custom flex-grow-1">
                                        <div class="progress-bar" style="width:@(progress)%"></div>
                                    </div>
                                    <small class="text-muted">@(progress)%</small>
                                </div>
                            </td>
                            <td><span class="badge-status @badgeClass">@statusText</span></td>
                            <td>
                                <div class="d-flex gap-1">
                                    <a href="@Url.Action("Details", new { id = da.MaDuAn })" class="btn-action btn-view" title="Xem chi tiết">
                                        <i class="fas fa-eye"></i>
                                    </a>
                                    <a href="@Url.Action("Edit", new { id = da.MaDuAn })" class="btn-action btn-edit" title="Sửa">
                                        <i class="fas fa-edit"></i>
                                    </a>
                                    <form method="post" asp-action="Delete" asp-route-id="@da.MaDuAn"
                                          onsubmit="return confirm('Bạn có chắc chắn muốn xóa dự án này? Hành động này sẽ xóa toàn bộ công việc liên quan.');">
                                        <button type="submit" class="btn-action btn-delete" title="Xóa">
                                            <i class="fas fa-trash"></i>
                                        </button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}
