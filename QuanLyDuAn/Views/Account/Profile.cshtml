@model QuanLyDuAn.Models.Taikhoan
@{
    ViewData["Title"] = "Hồ sơ cá nhân";
    var packages = ViewBag.Packages as List<QuanLyDuAn.Models.Goidichvu>;
}

<div class="row justify-content-center">
    <div class="col-lg-8">
        <div class="card">
            <div class="card-header d-flex align-items-center gap-2">
                <i class="fas fa-user-circle text-primary"></i>
                <span>Thông tin cá nhân</span>
            </div>
            <div class="card-body">
                @if (ViewBag.Error != null)
                {
                    <div class="alert alert-danger py-2">
                        <i class="fas fa-exclamation-circle me-2"></i>@ViewBag.Error
                    </div>
                }

                <div class="d-flex align-items-center gap-3 mb-4 pb-4" style="border-bottom:1px solid var(--gray-200);">
                    <div class="user-avatar" style="width:64px;height:64px;font-size:1.5rem;">
                        @Model.HoTen[0].ToString().ToUpper()
                    </div>
                    <div>
                        <h5 class="mb-1 fw-bold">@Model.HoTen</h5>
                        <div class="d-flex gap-2">
                            <span class="badge bg-secondary">@Model.VaiTro</span>
                            <span class="badge bg-info text-dark">@(Model.MaGoiNavigation?.TenGoi ?? "Gói Miễn Phí")</span>
                        </div>
                    </div>
                </div>

                <form method="post" asp-action="Profile">
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="form-label">Họ và tên <span class="text-danger">*</span></label>
                            <input type="text" name="hoTen" class="form-control" value="@Model.HoTen" required />
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label">Email</label>
                            <input type="email" name="email" class="form-control" value="@Model.Email" required />
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label">Số điện thoại</label>
                            <input type="text" name="soDienThoai" class="form-control" value="@Model.SoDienThoai" />
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label">Ngày tạo</label>
                            <input type="text" class="form-control" value="@Model.NgayTao.ToString("dd/MM/yyyy HH:mm")" disabled />
                        </div>
                    </div>
                    <div class="d-flex gap-2 mt-2">
                        <button type="submit" class="btn btn-primary-custom">
                            <i class="fas fa-save me-2"></i>Lưu thay đổi
                        </button>
                        <a href="@Url.Action("ChangePassword")" class="btn btn-outline-custom">
                            <i class="fas fa-key me-2"></i>Đổi mật khẩu
                        </a>
                    </div>
                </form>
            </div>
        </div>

        <div class="card mt-4">
            <div class="card-header d-flex align-items-center gap-2">
                <i class="fas fa-cubes text-primary"></i>
                <span>Gói dịch vụ &amp; Tài nguyên</span>
            </div>
            <div class="card-body">
                <div class="row align-items-center mb-4">
                    <div class="col-md-6">
                        <p class="mb-1 text-muted">Gói dịch vụ hiện tại</p>
                        <h4 class="fw-bold text-primary mb-0">@(Model.MaGoiNavigation?.TenGoi ?? "Chưa đăng ký gói")</h4>
                        <p class="small text-muted mb-0">@Model.MaGoiNavigation?.MoTa</p>
                    </div>
                    <div class="col-md-6">
                        <ul class="list-unstyled mb-0" style="font-size: .9rem; border-left: 2px solid var(--gray-200); padding-left: 20px;">
                            <li class="mb-1"><i class="fas fa-folder text-muted me-2"></i>Số dự án tối đa: <strong>@(Model.MaGoiNavigation?.SoDuAnToiDa.ToString() ?? "N/A")</strong></li>
                            <li class="mb-1"><i class="fas fa-users text-muted me-2"></i>Số thành viên tối đa: <strong>@(Model.MaGoiNavigation?.SoTvToiDa.ToString() ?? "N/A")</strong></li>
                            <li><i class="fas fa-hdd text-muted me-2"></i>Dung lượng tối đa: <strong>@(Model.MaGoiNavigation?.DungLuongMax.ToString() ?? "N/A") MB</strong></li>
                        </ul>
                    </div>
                </div>

                <h5 class="fw-bold mb-3" style="border-top:1px solid var(--gray-200); padding-top:20px;">Đăng ký / Nâng cấp gói dịch vụ</h5>
                <div class="row g-3">
                    @if (packages != null)
                    {
                        foreach (var pkg in packages)
                        {
                            var isCurrent = Model.MaGoi == pkg.MaGoi;
                            <div class="col-md-4">
                                <div class="p-3 border rounded @(isCurrent ? "bg-light border-primary" : "")" style="height:100%; position:relative;">
                                    @if (isCurrent)
                                    {
                                        <span class="badge bg-primary text-white position-absolute top-0 end-0 m-2" style="font-size:.7rem;">Đang sử dụng</span>
                                    }
                                    <h6 class="fw-bold mb-1">@pkg.TenGoi</h6>
                                    <p class="text-muted small mb-2" style="min-height:36px;">@pkg.MoTa</p>
                                    <div class="fw-bold text-dark mb-3" style="font-size:1.1rem;">
                                        @if (pkg.Gia == 0)
                                        {
                                            <span>Miễn phí</span>
                                        }
                                        else
                                        {
                                            <span>@pkg.Gia.ToString("#,##0") ₫/tháng</span>
                                        }
                                    </div>
                                    @if (isCurrent)
                                    {
                                        <button class="btn btn-sm btn-secondary w-100" disabled style="background-color: var(--gray-200); border-color: var(--gray-200); color: var(--gray-500);">Gói hiện tại</button>
                                    }
                                    else
                                    {
                                        <form method="post" asp-action="UpgradePlan">
                                            <input type="hidden" name="maGoi" value="@pkg.MaGoi" />
                                            <button type="submit" class="btn btn-sm btn-outline-primary w-100">Đăng ký gói này</button>
                                        </form>
                                    }
                                </div>
                            </div>
                        }
                    }
                </div>
            </div>
        </div>
    </div>
</div>
