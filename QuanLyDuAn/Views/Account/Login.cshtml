@{
    ViewData["Title"] = "Đăng nhập";
    Layout = "_Layout";
}

<div class="auth-wrapper">
    <div class="auth-card fade-in-up">
        <div class="auth-logo">
            <i class="fas fa-project-diagram"></i>
            <h2>Đăng nhập</h2>
            <p>Chào mừng bạn quay trở lại!</p>
        </div>

        @if (ViewBag.Error != null)
        {
            <div class="alert alert-danger py-2">
                <i class="fas fa-exclamation-circle me-2"></i>@ViewBag.Error
            </div>
        }

        <form method="post" asp-action="Login">
            <div class="mb-3">
                <label class="form-label">Email</label>
                <div class="input-group">
                    <span class="input-group-text"><i class="fas fa-envelope"></i></span>
                    <input type="email" name="email" class="form-control" placeholder="Nhập địa chỉ email" required />
                </div>
            </div>
            <div class="mb-3">
                <label class="form-label">Mật khẩu</label>
                <div class="input-group">
                    <span class="input-group-text"><i class="fas fa-lock"></i></span>
                    <input type="password" name="matKhau" class="form-control" placeholder="Nhập mật khẩu" required />
                </div>
            </div>
            <button type="submit" class="btn btn-primary-custom w-100 py-2 mt-2">
                <i class="fas fa-sign-in-alt me-2"></i>Đăng nhập
            </button>
        </form>

        <p class="text-center mt-4 mb-0" style="font-size:.9rem;color:var(--gray-500);">
            Chưa có tài khoản?
            <a href="@Url.Action("Register")" style="color:var(--primary);font-weight:600;text-decoration:none;">Đăng ký ngay</a>
        </p>
    </div>
</div>
