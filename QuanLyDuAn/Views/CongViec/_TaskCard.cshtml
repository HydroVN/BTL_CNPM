@model QuanLyDuAn.Models.Congviec
@{
    var priorityBadge = Model.MucDoUuTien switch
    {
        "Thap" => "badge-low",
        "TrungBinh" => "badge-medium",
        "Cao" => "badge-high",
        "KhanCap" => "badge-urgent",
        _ => "badge-medium"
    };
    var priorityText = Model.MucDoUuTien switch
    {
        "Thap" => "Thấp",
        "TrungBinh" => "TB",
        "Cao" => "Cao",
        "KhanCap" => "Khẩn",
        _ => Model.MucDoUuTien
    };
    var assigneeName = Model.MaThanhVienNavigation?.MaTaiKhoanNavigation?.HoTen;
}

<div class="kanban-card" data-id="@Model.MaCongViec" onclick="openTaskDetail('@Model.MaCongViec')">
    <div class="d-flex justify-content-between align-items-start mb-1">
        <span class="badge-status @priorityBadge" style="font-size:.68rem;">@priorityText</span>
        <form method="post" asp-controller="CongViec" asp-action="Delete"
              asp-route-id="@Model.MaCongViec" asp-route-maDuAn="@Model.MaDuAn"
              onclick="event.stopPropagation();"
              class="delete-task-form">
            <button type="button" class="btn-action btn-delete btn-delete-task" data-name="@Model.TenCongViec" style="width:24px;height:24px;font-size:.7rem;" title="Xóa">
                <i class="fas fa-times"></i>
            </button>
        </form>
    </div>
    <div class="card-title-text">@Model.TenCongViec</div>
    <div class="card-meta">
        <div class="card-assignee">
            @if (!string.IsNullOrEmpty(assigneeName))
            {
                <div class="mini-avatar">@assigneeName[0].ToString().ToUpper()</div>
                <span>@assigneeName</span>
            }
            else
            {
                <span class="text-muted"><i class="fas fa-user-slash me-1"></i>Chưa phân công</span>
            }
        </div>
        @if (Model.Deadline.HasValue)
        {
            <span><i class="fas fa-clock me-1"></i>@Model.Deadline.Value.ToString("dd/MM")</span>
        }
    </div>
</div>
